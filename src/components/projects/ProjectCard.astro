---
import type { Project } from 'src/types';
import { ArrowUpRight } from '@lucide/astro';

type Props = {
    project: Project;
    slug: string;
};

const { project, slug } = Astro.props;
---

<article
    class="group border-border/70 bg-card/60 hover:border-primary/40 relative rounded-xl border p-6 transition-all duration-300 hover:-translate-y-0.5"
    style="box-shadow: var(--shadow-card);"
>
    <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 rounded-xl opacity-0 transition-opacity duration-300 group-hover:opacity-100"
        style="box-shadow: var(--shadow-glow);"
    >
    </div>

    <div class="relative">
        <div class="flex items-start justify-between gap-4">
            <h3 class="text-foreground font-serif text-xl font-medium">
                <a href={`/projects/${slug}`}>{project.name}</a>
            </h3>
            <span class="text-primary-glow font-mono text-[10px] tracking-[0.18em] uppercase">
                {project.status}
            </span>
        </div>

        <p class="text-muted-foreground mt-3 text-sm leading-relaxed">
            {project.tagline}
        </p>

        <div class="mt-5 flex flex-wrap gap-1.5">
            {project.stack.map((t) => <span class="tech-tag">{t}</span>)}
        </div>

        {
            project.links && project.links.length > 0 && (
                <div class="mt-5 flex gap-4 text-sm">
                    {project.links.map((l) => (
                        <a
                            href={l.href}
                            target="_blank"
                            rel="noreferrer"
                            class="link-underline text-foreground/80 inline-flex items-center gap-1"
                        >
                            {l.label}
                            <ArrowUpRight size={14} />
                        </a>
                    ))}
                </div>
            )
        }
    </div>
</article>
