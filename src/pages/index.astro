---
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import LatticeBackground from '@/components/solid/LatticeBackground.tsx';
import SectionHeader from '@/components/SectionHeader.astro';
import type { Project } from '@/types';
import ProjectCard from '@/components/ProjectCard.astro';
import { ArrowUpRight, GitBranch, Mail, Package } from '@lucide/astro';
import { getCollection } from 'astro:content';

const year = new Date().getFullYear();

const skills = [
    {
        group: 'Languages',
        items: ['Java', 'Kotlin', 'Astro', 'SolidJS', 'SQL'],
    },
    {
        group: 'Platforms',
        items: ['Node.js', 'PaperMC', 'PostgreSQL'],
    },
    {
        group: 'Tools',
        items: ['Git', 'Gradle / Maven', 'Docker', 'Linux'],
    },
];

const projects = (await getCollection('projects')).filter((p) => p.data.featured == true);
---

<Layout>
    <LatticeBackground client:load />
    <SiteHeader
        nameHref="#top"
        links={[
            { href: '#now', label: 'Now' },
            { href: '#about', label: 'About' },
            { href: '#projects', label: 'Projects' },
            { href: '#contact', label: 'Contact' },
        ]}
        mobileLinks={[{ href: '#contact', label: 'Contact' }]}
    />
    <main class="mx-auto min-h-screen max-w-3xl px-6">
        <section id="top" class="pt-20 pb-24 md:pt-28 md:pb-32">
            <p
                class="text-primary-glow animate-fade-in font-mono text-xs tracking-[0.22em] uppercase"
            >
                Braden Kennedy
            </p>
            <h1
                class="text-foreground animate-fade-up mt-5 font-serif text-4xl leading-[1.1] font-medium tracking-tight md:text-6xl"
            >
                Backend & Systems Engineer.
            </h1>
            <p
                class="text-muted-foreground animate-fade-up mt-6 max-w-xl text-base [animation-delay:120ms] md:text-lg"
            >
                Mathematics & Computer Science · Eastern Washington University.
            </p>
        </section>
        <div
            class="h-px w-full bg-linear-to-r from-transparent via-[color-mix(in_oklch,var(--color-border),transparent_20%)] to-transparent"
        >
        </div>
        <section class="py-16">
            <SectionHeader id="now" eyebrow="Now" />
            <p class="text-foreground/85 max-w-2xl text-base leading-relaxed">
                Expanding two PaperMC plugins into a cohesive toolkit for server operators,
                exploring better data layers for plugin persistence, and sketching a few smaller
                side projects in between coursework.
            </p>
        </section>
        <section class="py-16">
            <SectionHeader id="about" eyebrow="About" title="A short résumé." />
            <div class="text-foreground/85 space-y-5">
                <p class="leading-relaxed">
                    I build backend systems — the parts of software that have to keep working when
                    nobody's looking. My interests sit at the intersection of clean architecture,
                    performance, and the kind of correctness that only really clicks once you've
                    seen a system fail.
                </p>
                <p class="leading-relaxed">
                    I'm currently a student at Eastern Washington University pursuing a double major
                    in Mathematics and Computer Science. The math half informs how I think about
                    software: precise definitions, clear invariants, and choosing the right
                    structure before writing the first line.
                </p>
            </div>
            <div class="mt-10 flex flex-wrap gap-2">
                <span class="focus-tag">Backend</span>
                <span class="focus-tag">Systems Architecture</span>
                <span class="focus-tag">Scalability</span>
                <span class="focus-tag">Java & Kotlin / JVM</span>
            </div>
            <div class="mt-12 grid gap-10 md:grid-cols-2">
                <div>
                    <h3 class="text-muted-foreground font-mono text-xs tracking-[0.22em] uppercase">
                        Education
                    </h3>
                    <p class="text-foreground mt-3 font-serif text-lg">
                        Eastern Washington University
                    </p>
                    <p class="text-muted-foreground text-sm">B.S. Mathematics & Computer Science</p>
                    <p class="text-muted-foreground text-sm">2025-Now</p>
                </div>
                <div>
                    <h3 class="text-muted-foreground font-mono text-xs tracking-[0.22em] uppercase">
                        Skills
                    </h3>
                    <dl class="mt-3 space-y-3">
                        {
                            skills.map((s) => (
                                <div key={s.group} class="grid grid-cols-[7rem_1fr] gap-3">
                                    <dt class="text-muted-foreground text-sm">{s.group}</dt>
                                    <dd class="text-foreground/85 text-sm">
                                        {s.items.join(' · ')}
                                    </dd>
                                </div>
                            ))
                        }
                    </dl>
                </div>
            </div>
        </section>
        <section class="py-16">
            <SectionHeader id="projects" eyebrow="Projects" title="Things I've built." />
            <div class="grid gap-5">
                {projects.map((p) => <ProjectCard project={p.data} />)}
            </div>
            <p class="text-muted-foreground mt-6 mb-5 font-mono text-xs">// more on the way.</p>

            <!--<a-->
            <!--    href="/projects"-->
            <!--    class="link-underline text-foreground/90 inline-flex items-center gap-2 font-mono"-->
            <!--&gt;-->
            <!--    <Package size={16} class="text-primary-glow" />-->
            <!--    View More-->
            <!--    <ArrowUpRight size={14} />-->
            <!--</a>-->
        </section>
        <section class="py-16">
            <SectionHeader id="contact" eyebrow="Contact" title="Get in touch." />

            <p class="text-foreground/85 max-w-xl">
                Open to interesting backend problems, collaborations, and conversations about
                systems that have to scale. The fastest way to reach me is email.
            </p>

            <div class="mt-8 flex flex-col gap-3 text-sm">
                <a
                    href={`mailto:braden@bradenkennedy.com`}
                    class="link-underline text-foreground/90 inline-flex items-center gap-2 font-mono"
                >
                    <Mail size={16} class="text-primary-glow" />
                    braden@bradenkennedy.com
                </a>

                <a
                    href="https://github.com/bradenk04/"
                    target="_blank"
                    rel="noreferrer"
                    class="link-underline text-foreground/90 inline-flex items-center gap-2 font-mono"
                >
                    <GitBranch size={16} class="text-primary-glow" />
                    GitHub
                    <ArrowUpRight size={14} />
                </a>
            </div>
        </section>
    </main>
    <footer class="mx-auto max-w-3xl px-6 py-10">
        <div
            class="text-muted-foreground flex flex-col items-start justify-between gap-2 border-t pt-6 text-xs sm:flex-row sm:items-center"
            style="border-color: color-mix(in oklch, var(--border) 60%, transparent);"
        >
            <span class="font-mono">© {year} Braden Kennedy</span>
            <span class="font-mono">bradenkennedy.com</span>
        </div>
    </footer>
</Layout>
