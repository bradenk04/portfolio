---
import '@/styles/starwind.css';
import Layout from '@/layouts/Layout.astro';

const year = new Date().getFullYear();
---

<Layout>
    <main class="mx-auto max-w-3xl px-6"></main>
    <footer class="mx-auto max-w-3xl px-6 py-10">
        <div
            class="text-muted-foreground flex flex-col items-start justify-between gap-2 border-t pt-6 text-xs sm:flex-row sm:items-center"
            style="border-color: hsl(var(--border) / 0.6);"
        >
            <span class="font-mono">© {year} Braden Kennedy</span>
            <span class="font-mono">bradenkennedy.com</span>
        </div>
    </footer>
</Layout>
